{
  "name": "game-boy-camera-picture-extractor",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "dev": "pnpm --filter gbcam-extract-web dev",
    "dev:host": "pnpm --filter gbcam-extract-web dev --host",
    "typecheck": "pnpm -r run typecheck",
    "extract": "pnpm --filter gbcam-extract run extract",
    "test:pipeline": "pnpm --filter gbcam-extract run test:pipeline"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"]
  },
  "volta": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  }
}
