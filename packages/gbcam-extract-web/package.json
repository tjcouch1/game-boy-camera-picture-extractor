{
  "name": "gbcam-extract-web",
  "version": "0.3.0",
  "author": "TJ Couch",
  "license": "MIT",
  "description": "Static website and PWA that extracts and cleans Game Boy Camera images from pictures",
  "repository": {
    "type": "git",
    "url": "https://github.com/tjcouch1/game-boy-camera-picture-extractor.git",
    "directory": "packages/gbcam-extract-web"
  },
  "type": "module",
  "scripts": {
    "build:instructions": "node scripts/generate-instructions.ts",
    "dev": "pnpm build:instructions && vite",
    "dev:host": "pnpm build:instructions && vite --host",
    "build": "pnpm build:instructions && tsc -b && vite build",
    "preview": "pnpm build:instructions && vite preview",
    "preview:host": "pnpm build:instructions && vite preview --host",
    "serve": "node scripts/serve-dist.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/generate-instructions.ts && node scripts/generate-licenses.ts"
  },
  "dependencies": {
    "gbcam-extract": "workspace:*",
    "lucide-react": "^1.11.0",
    "markdown-to-jsx": "^9.7.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "@types/license-checker": "^25.0.6",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "http-server": "^14.1.1",
    "license-checker": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.0.0"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
